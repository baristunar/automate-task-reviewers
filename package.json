    "format:check": "prettier . --check"
  },
  "devDependencies": {
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "husky": "^9.1.7",
    "prettier": "^3.5.3",
    "vite": "^5.4.11"
  }
}
