{
  "name": "automate-task-reviewers",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "prepare": "husky",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "check": "node --check app.js && node --check src/main.js",
    "lint": "eslint .",
